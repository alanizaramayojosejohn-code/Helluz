{
   "name": "helluz",
   "version": "0.0.0",
   "scripts": {
      "ng": "ng",
      "start": "ng serve",
      "build": "ng build",
      "build:prod": "ng build --configuration=production",
      "watch": "ng build --watch --configuration development",
      "test": "vitest",
      "test:ui": "vitest --ui",
      "test:run": "vitest run",
      "test:coverage": "vitest run --coverage",
      "lint": "ng lint",
      "deploy:prod": "ng build --configuration=production && firebase deploy --project production",
      "deploy:dev": "ng build && firebase deploy --project default"
   },
   "private": true,
   "packageManager": "bun@1.3.3",
   "dependencies": {
      "@angular/animations": "21.2.1",
      "@angular/cdk": "^21.0.5",
      "@angular/common": "21.2.1",
      "@angular/compiler": "21.2.1",
      "@angular/core": "21.2.1",
      "@angular/fire": "^20.0.1",
      "@angular/forms": "21.2.1",
      "@angular/material": "^21.0.5",
      "@angular/material-moment-adapter": "^21.2.0",
      "@angular/platform-browser": "21.2.1",
      "@angular/router": "21.2.1",
      "firebase": "^11.0.0",
      "moment": "^2.30.1",
      "rxjs": "~7.8.0",
      "tslib": "^2.3.0",
      "uuid": "^13.0.0",
      "zone.js": "^0.16.0"
   },
   "devDependencies": {
      "@analogjs/vite-plugin-angular": "^2.3.1",
      "@angular-devkit/build-angular": "^21.2.1",
      "@angular-eslint/builder": "21.1.0",
      "@angular/build": "^21.0.4",
      "@angular/compiler-cli": "^21.2.1",
      "@angular/platform-browser-dynamic": "21.2.1",
      "@eslint/js": "^9.39.1",
      "@vitest/coverage-v8": "^4.0.16",
      "@vitest/ui": "^4.0.18",
      "angular-eslint": "21.1.0",
      "autoprefixer": "^10.4.23",
      "eslint": "^9.39.1",
      "jsdom": "^28.1.0",
      "postcss": "^8.5.6",
      "tailwindcss": "3.4.0",
      "typescript": "~5.9.2",
      "typescript-eslint": "8.47.0",
      "vitest": "^4.0.18"
   }
}
